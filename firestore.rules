rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isMediaManager() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/mediaManagers/$(request.auth.uid));
    }

    function validString(text, minLen, maxLen) {
      return text is string
        && text.size() >= minLen
        && text.size() <= maxLen;
    }

    function isValidUsername(username) {
      return username is string
        && username.size() >= 2
        && username.size() <= 20
        && username.matches('^[a-zA-Z0-9 _-]+$');
    }

    function isValidMessage(text) {
      return text is string
        && text.size() > 0
        && text.size() <= 10000;
    }

    // Reaction toggle on a parent doc's reactedBy array: the caller may only
    // add or remove their own uid, and reactionCount must move by the matching
    // ±1. Count uses increment semantics (not array size) so legacy docs whose
    // reactionCount predates the reactedBy array can still be toggled.
    function isValidReactionToggle(before, after, oldCount, newCount) {
      let added = after.difference(before);
      let removed = before.difference(after);
      return (added == [request.auth.uid].toSet() && removed.size() == 0 && newCount == oldCount + 1)
        || (removed == [request.auth.uid].toSet() && added.size() == 0 && newCount == oldCount - 1);
    }

    // reactedBy/reactionCount may be present at creation only as empty/zero
    function hasNoPriorReactions(data) {
      return (!('reactedBy' in data) || data.reactedBy == [])
        && (!('reactionCount' in data) || data.reactionCount == 0);
    }

    // Poll options: 2-6 plain-text labels, 1-100 chars each. Rules have no
    // loops, so each index is checked explicitly up to the size cap.
    function isValidPollOptions(options) {
      return options is list
        && options.size() >= 2 && options.size() <= 6
        && validString(options[0], 1, 100)
        && validString(options[1], 1, 100)
        && (options.size() < 3 || validString(options[2], 1, 100))
        && (options.size() < 4 || validString(options[3], 1, 100))
        && (options.size() < 5 || validString(options[4], 1, 100))
        && (options.size() < 6 || validString(options[5], 1, 100));
    }

    // A poll may only be created with a valid question/options/mode and no
    // votes yet (mirrors hasNoPriorReactions).
    function isValidPollCreate(data) {
      return (!('pollQuestion' in data) && !('pollOptions' in data) && !('pollMultiple' in data))
        || (
          validString(data.pollQuestion, 1, 300)
          && data.pollMultiple is bool
          && isValidPollOptions(data.pollOptions)
          && (!('pollVotes' in data) || data.pollVotes == {})
        );
    }

    // A voter may only replace their own option-index selection in pollVotes.
    // `before`/`after` are the caller's own array (before/after the write);
    // indices are unrolled the same way as isValidPollOptions since rules
    // have no loop construct.
    function isValidPollVote(before, after, optionCount, multiple) {
      return after is list
        && before != after
        && after.size() == after.toSet().size()
        && after.size() <= (multiple ? optionCount : 1)
        && (after.size() < 1 || (after[0] is int && after[0] >= 0 && after[0] < optionCount))
        && (after.size() < 2 || (after[1] is int && after[1] >= 0 && after[1] < optionCount))
        && (after.size() < 3 || (after[2] is int && after[2] >= 0 && after[2] < optionCount))
        && (after.size() < 4 || (after[3] is int && after[3] >= 0 && after[3] < optionCount))
        && (after.size() < 5 || (after[4] is int && after[4] >= 0 && after[4] < optionCount))
        && (after.size() < 6 || (after[5] is int && after[5] >= 0 && after[5] < optionCount));
    }

    // Denormalised username on a created doc must match the author's profile,
    // so users can't post under someone else's name. Admins are exempt
    // (Film Club Bot announcements post with a bot identity).
    function usernameMatchesProfile(username) {
      return username == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username
        || isAdmin();
    }

    function isValidListItem(data) {
      return data.keys().hasOnly([
          'type', 'userText', 'order', 'timestamp',
          'addedByUserId', 'addedByUsername', 'addedByAvatar',
          'albumId', 'albumTitle', 'albumArtist', 'albumCover',
          'title', 'imageUrl', 'linkUrl'
        ])
        && data.type in ['album', 'custom']
        && data.userText is string && data.userText.size() <= 2000
        && data.order is number
        && (!('albumId' in data) || validString(data.albumId, 1, 100))
        && (!('albumTitle' in data) || validString(data.albumTitle, 0, 300))
        && (!('albumArtist' in data) || validString(data.albumArtist, 0, 300))
        && (!('albumCover' in data) || validString(data.albumCover, 0, 1000))
        && (!('title' in data) || validString(data.title, 0, 300))
        && (!('imageUrl' in data) || validString(data.imageUrl, 0, 1000))
        && (!('linkUrl' in data) || validString(data.linkUrl, 0, 1000))
        && (!('addedByUserId' in data) || validString(data.addedByUserId, 1, 128))
        && (!('addedByUsername' in data) || validString(data.addedByUsername, 0, 50))
        && (!('addedByAvatar' in data) || validString(data.addedByAvatar, 0, 200));
    }

    function isValidNextFilm(film) {
      return film is map
        && film.tmdbId is int
        && film.title is string && film.title.size() >= 1 && film.title.size() <= 200
        && film.releaseYear is string && film.releaseYear.size() <= 10
        && (film.posterPath == null || (film.posterPath is string && film.posterPath.size() <= 200))
        && film.overview is string && film.overview.size() <= 2000
        && film.pitch is string && film.pitch.size() <= 600
        && film.submittedByUsername is string && film.submittedByUsername.size() <= 50;
    }

    // Admin collection - managed via Firebase Console only
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    // Media Managers collection - managed via Firebase Console only
    match /mediaManagers/{userId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    // Media Manager audit logs - written by backend server only (Admin SDK bypasses rules)
    match /mediaManagerLogs/{logId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();

      allow create: if isOwner(userId)
        && request.resource.data.keys().hasOnly(['username', 'avatar', 'color', 'shape', 'bio', 'locationFlag', 'locationText', 'nekoEnabled', 'designToolEnabled'])
        && isValidUsername(request.resource.data.username)
        && (!('avatar' in request.resource.data) || validString(request.resource.data.avatar, 0, 200))
        && (!('color' in request.resource.data) || validString(request.resource.data.color, 1, 50))
        && (!('shape' in request.resource.data) || validString(request.resource.data.shape, 1, 50))
        && (!('bio' in request.resource.data) || validString(request.resource.data.bio, 0, 500))
        && (!('locationFlag' in request.resource.data) || validString(request.resource.data.locationFlag, 0, 20))
        && (!('locationText' in request.resource.data) || validString(request.resource.data.locationText, 0, 100))
        && (!('nekoEnabled' in request.resource.data) || request.resource.data.nekoEnabled is bool)
				&& (!('designToolEnabled' in request.resource.data) || request.resource.data.designToolEnabled is bool);

      allow update: if isOwner(userId)
        && request.resource.data.keys().hasOnly(['username', 'avatar', 'color', 'shape', 'bio', 'locationFlag', 'locationText', 'nekoEnabled', 'designToolEnabled'])
        && isValidUsername(request.resource.data.username)
        && (!('avatar' in request.resource.data) || validString(request.resource.data.avatar, 0, 200))
        && (!('color' in request.resource.data) || validString(request.resource.data.color, 1, 50))
        && (!('shape' in request.resource.data) || validString(request.resource.data.shape, 1, 50))
        && (!('bio' in request.resource.data) || validString(request.resource.data.bio, 0, 500))
        && (!('locationFlag' in request.resource.data) || validString(request.resource.data.locationFlag, 0, 20))
        && (!('locationText' in request.resource.data) || validString(request.resource.data.locationText, 0, 100))
        && (!('nekoEnabled' in request.resource.data) || request.resource.data.nekoEnabled is bool)
				&& (!('designToolEnabled' in request.resource.data) || request.resource.data.designToolEnabled is bool);

      allow delete: if false;
    }

    // Messages - main forum
    match /messages/{messageId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 10000
        && (request.resource.data.text.size() > 0 || 'imageId' in request.resource.data || 'pollQuestion' in request.resource.data)
        && request.resource.data.keys().hasOnly(['text', 'userId', 'timestamp', 'lastActivityAt', 'username', 'avatar', 'imageId', 'posterUrl', 'reactedBy', 'reactionCount', 'pollQuestion', 'pollOptions', 'pollMultiple', 'pollVotes'])
        && hasNoPriorReactions(request.resource.data)
        && isValidPollCreate(request.resource.data)
        && request.resource.data.timestamp == request.time
        && validString(request.resource.data.username, 1, 50)
        && usernameMatchesProfile(request.resource.data.username)
        && validString(request.resource.data.avatar, 0, 200)
        && (!('imageId' in request.resource.data) || (request.resource.data.imageId is string && request.resource.data.imageId.size() == 36))
        && (!('posterUrl' in request.resource.data) || validString(request.resource.data.posterUrl, 0, 500));

      allow update: if isOwner(resource.data.userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'editedAt'])
        && isValidMessage(request.resource.data.text)
        && request.resource.data.editedAt == request.time;

      // Reaction toggle: own uid in/out of reactedBy, count kept in sync
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactedBy', 'reactionCount'])
        && isValidReactionToggle(
          resource.data.get('reactedBy', []).toSet(),
          request.resource.data.reactedBy.toSet(),
          resource.data.get('reactionCount', 0),
          request.resource.data.reactionCount
        );

      // Poll vote toggle: caller may only replace their own entry in pollVotes.
      allow update: if isSignedIn()
        && 'pollOptions' in resource.data
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pollVotes'])
        && request.resource.data.pollVotes.diff(resource.data.get('pollVotes', {})).affectedKeys().hasOnly([request.auth.uid])
        && isValidPollVote(
          resource.data.get('pollVotes', {}).get(request.auth.uid, []),
          request.resource.data.pollVotes.get(request.auth.uid, []),
          resource.data.pollOptions.size(),
          resource.data.pollMultiple
        );

      // Reply-count bump on reply create/delete: ±1 only
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastActivityAt', 'replyCount'])
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['lastActivityAt']) || request.resource.data.lastActivityAt == request.time)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['replyCount'])
          || request.resource.data.replyCount == resource.data.get('replyCount', 0) + 1
          || request.resource.data.replyCount == resource.data.get('replyCount', 0) - 1);

      allow delete: if isOwner(resource.data.userId) || isAdmin();

      // Retired: reactions live on the parent doc's reactedBy array.
      // Legacy subcollection kept readable during transition.
      match /reactions/{reactionId} {
        allow read: if isSignedIn();
        allow create, update, delete: if false;
      }

      match /replies/{replyId} {
        allow read: if isSignedIn();

        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() <= 10000
          && (request.resource.data.text.size() > 0 || 'imageId' in request.resource.data)
          && request.resource.data.keys().hasOnly(['text', 'userId', 'timestamp', 'username', 'avatar', 'imageId', 'reactedBy', 'reactionCount'])
          && hasNoPriorReactions(request.resource.data)
          && request.resource.data.timestamp == request.time
          && validString(request.resource.data.username, 1, 50)
          && usernameMatchesProfile(request.resource.data.username)
          && validString(request.resource.data.avatar, 0, 200)
          && (!('imageId' in request.resource.data) || (request.resource.data.imageId is string && request.resource.data.imageId.size() == 36));

        allow update: if isOwner(resource.data.userId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'editedAt'])
          && isValidMessage(request.resource.data.text)
          && request.resource.data.editedAt == request.time;

        // Reaction toggle: own uid in/out of reactedBy, count kept in sync
        allow update: if isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactedBy', 'reactionCount'])
          && isValidReactionToggle(
            resource.data.get('reactedBy', []).toSet(),
            request.resource.data.reactedBy.toSet(),
            resource.data.get('reactionCount', 0),
            request.resource.data.reactionCount
          );

        allow delete: if isOwner(resource.data.userId) || isAdmin();

        // Retired: reactions live on the parent reply's reactedBy array.
        match /reactions/{reactionId} {
          allow read: if isSignedIn();
          allow create, update, delete: if false;
        }
      }
    }

    // Film Club Messages - dedicated film discussion chat
    // Mirrors messages rules but allows posterUrl for film announcements
    match /filmClubMessages/{messageId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 10000
        && (request.resource.data.text.size() > 0 || 'imageId' in request.resource.data || 'pollQuestion' in request.resource.data)
        && request.resource.data.keys().hasOnly(['text', 'userId', 'timestamp', 'lastActivityAt', 'username', 'avatar', 'imageId', 'posterUrl', 'reactedBy', 'reactionCount', 'pollQuestion', 'pollOptions', 'pollMultiple', 'pollVotes'])
        && hasNoPriorReactions(request.resource.data)
        && isValidPollCreate(request.resource.data)
        && request.resource.data.timestamp == request.time
        && validString(request.resource.data.username, 1, 50)
        && usernameMatchesProfile(request.resource.data.username)
        && validString(request.resource.data.avatar, 0, 200)
        && (!('imageId' in request.resource.data) || (request.resource.data.imageId is string && request.resource.data.imageId.size() == 36))
        && (!('posterUrl' in request.resource.data) || validString(request.resource.data.posterUrl, 0, 500));

      allow update: if isOwner(resource.data.userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'editedAt'])
        && isValidMessage(request.resource.data.text)
        && request.resource.data.editedAt == request.time;

      // Reaction toggle: own uid in/out of reactedBy, count kept in sync
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactedBy', 'reactionCount'])
        && isValidReactionToggle(
          resource.data.get('reactedBy', []).toSet(),
          request.resource.data.reactedBy.toSet(),
          resource.data.get('reactionCount', 0),
          request.resource.data.reactionCount
        );

      // Poll vote toggle: caller may only replace their own entry in pollVotes.
      allow update: if isSignedIn()
        && 'pollOptions' in resource.data
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pollVotes'])
        && request.resource.data.pollVotes.diff(resource.data.get('pollVotes', {})).affectedKeys().hasOnly([request.auth.uid])
        && isValidPollVote(
          resource.data.get('pollVotes', {}).get(request.auth.uid, []),
          request.resource.data.pollVotes.get(request.auth.uid, []),
          resource.data.pollOptions.size(),
          resource.data.pollMultiple
        );

      // Reply-count bump on reply create/delete: ±1 only
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastActivityAt', 'replyCount'])
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['lastActivityAt']) || request.resource.data.lastActivityAt == request.time)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['replyCount'])
          || request.resource.data.replyCount == resource.data.get('replyCount', 0) + 1
          || request.resource.data.replyCount == resource.data.get('replyCount', 0) - 1);

      allow delete: if isOwner(resource.data.userId) || isAdmin();

      // Retired: reactions live on the parent doc's reactedBy array.
      // Legacy subcollection kept readable during transition.
      match /reactions/{reactionId} {
        allow read: if isSignedIn();
        allow create, update, delete: if false;
      }

      match /replies/{replyId} {
        allow read: if isSignedIn();

        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() <= 10000
          && (request.resource.data.text.size() > 0 || 'imageId' in request.resource.data)
          && request.resource.data.keys().hasOnly(['text', 'userId', 'timestamp', 'username', 'avatar', 'imageId', 'reactedBy', 'reactionCount'])
          && hasNoPriorReactions(request.resource.data)
          && request.resource.data.timestamp == request.time
          && validString(request.resource.data.username, 1, 50)
          && usernameMatchesProfile(request.resource.data.username)
          && validString(request.resource.data.avatar, 0, 200)
          && (!('imageId' in request.resource.data) || (request.resource.data.imageId is string && request.resource.data.imageId.size() == 36));

        allow update: if isOwner(resource.data.userId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'editedAt'])
          && isValidMessage(request.resource.data.text)
          && request.resource.data.editedAt == request.time;

        // Reaction toggle: own uid in/out of reactedBy, count kept in sync
        allow update: if isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactedBy', 'reactionCount'])
          && isValidReactionToggle(
            resource.data.get('reactedBy', []).toSet(),
            request.resource.data.reactedBy.toSet(),
            resource.data.get('reactionCount', 0),
            request.resource.data.reactionCount
          );

        allow delete: if isOwner(resource.data.userId) || isAdmin();

        // Retired: reactions live on the parent reply's reactedBy array.
        match /reactions/{reactionId} {
          allow read: if isSignedIn();
          allow create, update, delete: if false;
        }
      }
    }

    // Issues - bug/problem reports. Mirrors messages rules minus polls and
    // posterUrl; adds a status field toggled by admins only.
    match /issues/{issueId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 10000
        && (request.resource.data.text.size() > 0 || 'imageId' in request.resource.data)
        && request.resource.data.keys().hasOnly(['text', 'userId', 'timestamp', 'lastActivityAt', 'username', 'avatar', 'imageId', 'reactedBy', 'reactionCount', 'status'])
        && request.resource.data.status == 'inprogress'
        && hasNoPriorReactions(request.resource.data)
        && request.resource.data.timestamp == request.time
        && validString(request.resource.data.username, 1, 50)
        && usernameMatchesProfile(request.resource.data.username)
        && validString(request.resource.data.avatar, 0, 200)
        && (!('imageId' in request.resource.data) || (request.resource.data.imageId is string && request.resource.data.imageId.size() == 36));

      allow update: if isOwner(resource.data.userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'editedAt'])
        && isValidMessage(request.resource.data.text)
        && request.resource.data.editedAt == request.time;

      // Reaction toggle: own uid in/out of reactedBy, count kept in sync
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactedBy', 'reactionCount'])
        && isValidReactionToggle(
          resource.data.get('reactedBy', []).toSet(),
          request.resource.data.reactedBy.toSet(),
          resource.data.get('reactionCount', 0),
          request.resource.data.reactionCount
        );

      // Reply-count bump on reply create/delete: ±1 only
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastActivityAt', 'replyCount'])
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['lastActivityAt']) || request.resource.data.lastActivityAt == request.time)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['replyCount'])
          || request.resource.data.replyCount == resource.data.get('replyCount', 0) + 1
          || request.resource.data.replyCount == resource.data.get('replyCount', 0) - 1);

      // Status toggle: admin only
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status in ['inprogress', 'complete'];

      allow delete: if isOwner(resource.data.userId) || isAdmin();

      match /replies/{replyId} {
        allow read: if isSignedIn();

        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() <= 10000
          && (request.resource.data.text.size() > 0 || 'imageId' in request.resource.data)
          && request.resource.data.keys().hasOnly(['text', 'userId', 'timestamp', 'username', 'avatar', 'imageId', 'reactedBy', 'reactionCount'])
          && hasNoPriorReactions(request.resource.data)
          && request.resource.data.timestamp == request.time
          && validString(request.resource.data.username, 1, 50)
          && usernameMatchesProfile(request.resource.data.username)
          && validString(request.resource.data.avatar, 0, 200)
          && (!('imageId' in request.resource.data) || (request.resource.data.imageId is string && request.resource.data.imageId.size() == 36));

        allow update: if isOwner(resource.data.userId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'editedAt'])
          && isValidMessage(request.resource.data.text)
          && request.resource.data.editedAt == request.time;

        // Reaction toggle: own uid in/out of reactedBy, count kept in sync
        allow update: if isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactedBy', 'reactionCount'])
          && isValidReactionToggle(
            resource.data.get('reactedBy', []).toSet(),
            request.resource.data.reactedBy.toSet(),
            resource.data.get('reactionCount', 0),
            request.resource.data.reactionCount
          );

        allow delete: if isOwner(resource.data.userId) || isAdmin();
      }
    }

    // Lists - user-created music lists.
    // Private lists are readable only by their owner. Queries must constrain
    // to isPublic == true or userId == auth.uid (rules are not filters).
    match /lists/{listId} {
      allow get: if isSignedIn()
        && (resource.data.isPublic != false || resource.data.userId == request.auth.uid);

      allow list: if isSignedIn()
        && (resource.data.isPublic == true || resource.data.userId == request.auth.uid);

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasOnly(['title', 'userId', 'username', 'timestamp', 'itemCount', 'isPublic', 'isCollaborative', 'lastUpdated', 'lastItemImage', 'lastItemLink', 'lastItemAddedByAvatar'])
        && validString(request.resource.data.title, 1, 200)
        && usernameMatchesProfile(request.resource.data.username)
        && request.resource.data.timestamp == request.time;

      allow update: if isOwner(resource.data.userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'itemCount', 'isPublic', 'isCollaborative', 'lastUpdated', 'lastItemImage', 'lastItemLink', 'lastItemAddedByAvatar'])
        && validString(request.resource.data.title, 1, 200);

      allow update: if isSignedIn()
        && resource.data.isCollaborative == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'itemCount', 'lastUpdated', 'lastItemImage', 'lastItemLink', 'lastItemAddedByAvatar'])
        && validString(request.resource.data.title, 1, 200);

      allow delete: if isOwner(resource.data.userId);

      match /items/{itemId} {
        // Items inherit the parent list's visibility (one billed read per request)
        allow read: if isSignedIn()
          && (get(/databases/$(database)/documents/lists/$(listId)).data.isPublic != false
            || get(/databases/$(database)/documents/lists/$(listId)).data.userId == request.auth.uid);

        allow create, update: if isSignedIn()
          && get(/databases/$(database)/documents/lists/$(listId)).data.userId == request.auth.uid
          && isValidListItem(request.resource.data);

        allow delete: if isSignedIn()
          && get(/databases/$(database)/documents/lists/$(listId)).data.userId == request.auth.uid;

        allow create, update: if isSignedIn()
          && get(/databases/$(database)/documents/lists/$(listId)).data.isCollaborative == true
          && isValidListItem(request.resource.data);

        allow delete: if isSignedIn()
          && get(/databases/$(database)/documents/lists/$(listId)).data.isCollaborative == true;
      }
    }

    // News posts - admin-only creation
    match /news/{newsId} {
      allow read: if isSignedIn();

      allow create: if isAdmin()
        && request.resource.data.userId == request.auth.uid
        && isValidMessage(request.resource.data.text)
        && request.resource.data.keys().hasOnly(['text', 'userId', 'timestamp', 'username', 'avatar'])
        && request.resource.data.timestamp == request.time
        && validString(request.resource.data.username, 1, 50)
        && validString(request.resource.data.avatar, 0, 200);

      allow update: if isAdmin() && isOwner(resource.data.userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'editedAt'])
        && isValidMessage(request.resource.data.text)
        && request.resource.data.editedAt == request.time;

      allow delete: if isAdmin();

      match /reactions/{reactionId} {
        allow read: if isSignedIn();

        allow create: if isSignedIn()
          && reactionId == request.auth.uid
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.keys().hasOnly(['userId', 'username', 'timestamp'])
          && validString(request.resource.data.username, 1, 50);

        allow delete: if isSignedIn() && reactionId == request.auth.uid;
        allow update: if false;
      }
    }

    // Stickers
    match /stickers/{stickerId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasOnly(['userId', 'albumId', 'text', 'position', 'sticker', 'timestamp', 'favoriteTrackId', 'favoriteTrackTitle', 'albumName', 'albumArtist'])
        && isValidMessage(request.resource.data.text)
        && validString(request.resource.data.albumId, 1, 100)
        && validString(request.resource.data.sticker, 1, 200)
        && request.resource.data.position is map
        && request.resource.data.position.x is number
        && request.resource.data.position.y is number
        && (!('favoriteTrackId' in request.resource.data) || validString(request.resource.data.favoriteTrackId, 0, 100))
        && (!('favoriteTrackTitle' in request.resource.data) || validString(request.resource.data.favoriteTrackTitle, 0, 300))
        && (!('albumName' in request.resource.data) || validString(request.resource.data.albumName, 0, 300))
        && (!('albumArtist' in request.resource.data) || validString(request.resource.data.albumArtist, 0, 300))
        && request.resource.data.timestamp == request.time;

      allow update: if isOwner(resource.data.userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'editedAt'])
        && isValidMessage(request.resource.data.text);

      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // Film Club collection
    match /filmClub/{monthId} {
      allow read: if isSignedIn();

      // Admin can create/update currentFilm, downloadLinks, directDownloadLinks, and currentFilmDescription
      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly(['currentFilm', 'downloadLinks', 'directDownloadLinks', 'currentFilmDescription']);

      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentFilm', 'downloadLinks', 'directDownloadLinks', 'currentFilmDescription']);

      // Admin can overwrite nextFilm + winnerCalculated (escape hatch for stuck/corrupt state)
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nextFilm', 'winnerCalculated'])
        && request.resource.data.winnerCalculated is bool
        && isValidNextFilm(request.resource.data.nextFilm);

      // Any authenticated user can write the IRV result, but only once and only a valid shape
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(['nextFilm', 'winnerCalculated'])
        && request.resource.data.winnerCalculated == true
        && request.resource.data.winnerCalculated is bool
        && isValidNextFilm(request.resource.data.nextFilm);

      allow update: if isSignedIn()
        && !resource.data.winnerCalculated
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nextFilm', 'winnerCalculated'])
        && request.resource.data.winnerCalculated == true
        && request.resource.data.winnerCalculated is bool
        && isValidNextFilm(request.resource.data.nextFilm);

      // Submissions subcollection — one doc per user+film (docId = {userId}_{tmdbId})
      match /submissions/{submissionId} {
        allow read: if isSignedIn();

        allow create, update: if isSignedIn()
          && submissionId.matches(request.auth.uid + '_.*')
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.keys().hasOnly([
               'userId', 'username', 'title', 'releaseYear',
               'posterPath', 'overview', 'pitch', 'tmdbId', 'timestamp'
             ])
          && request.resource.data.username ==
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username
          && isValidUsername(request.resource.data.username)
          && validString(request.resource.data.title, 1, 200)
          && validString(request.resource.data.pitch, 0, 600)
          && validString(request.resource.data.overview, 0, 2000)
          && request.resource.data.tmdbId is int
          && (request.resource.data.posterPath == null
              || (request.resource.data.posterPath is string
                  && request.resource.data.posterPath.size() <= 200));

        allow delete: if isSignedIn()
          && (submissionId.matches(request.auth.uid + '_.*') || isAdmin());
      }

      // Votes subcollection — one doc per user (docId = userId)
      match /votes/{userId} {
        allow read: if isSignedIn();

        allow create, update: if isSignedIn()
          && request.auth.uid == userId
          && request.resource.data.ranking is list;

        allow delete: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Travel recommendations — writes go through the backend server (Admin SDK bypasses rules)
    match /places/{placeId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;

      match /contributions/{userId} {
        allow read: if isSignedIn();
        allow create, update, delete: if false;
      }
    }

    // Wiki - admin write, authenticated read
    match /wiki/{docId} {
      allow read: if isSignedIn();

      allow create, update: if isAdmin()
        && request.resource.data.keys().hasOnly(['text', 'updatedAt', 'updatedBy'])
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 100000
        && request.resource.data.updatedBy == request.auth.uid;
    }
    
    // Cinema state — admin-set next showing time, read by all signed-in users.
    match /cinema/{docId} {
      allow read: if isSignedIn();
      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly(['nextShowingAt'])
        && request.resource.data.nextShowingAt is string;
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nextShowingAt']);
      allow delete: if isAdmin();
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
